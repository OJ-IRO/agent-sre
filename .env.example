# =============================================================================
# Google AI / Gemini
# =============================================================================
# Get an API key at https://aistudio.google.com/apikey OR use Vertex (below).
GOOGLE_API_KEY=

# Set to "true" to use Vertex AI instead of the direct Gemini API.
GOOGLE_GENAI_USE_VERTEXAI=false

# Required when GOOGLE_GENAI_USE_VERTEXAI=true and for Cloud Run deploys.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# Gemini model selection
# =============================================================================
# Planner: high-reasoning model. Used by Agent SRE for diagnosis, fix proposals.
# NOTE: gemini-3.1-pro-preview is paid-tier only. Stick with flash for the free tier.
GEMINI_PLANNER_MODEL=gemini-3-flash-preview

# Worker: fast/cheap model. Used for clustering, eval synthesis, LLM-as-judge.
GEMINI_WORKER_MODEL=gemini-3-flash-preview

# =============================================================================
# Arize Phoenix (observability + MCP)
# =============================================================================
# Create a Phoenix Cloud account at https://app.phoenix.arize.com.
# Keys start with "px_live_..." — this is a Phoenix Cloud key, NOT an Arize AX key.
PHOENIX_API_KEY=

# Phoenix Cloud base URL — update path if you use a workspace-scoped URL.
PHOENIX_BASE_URL=https://app.phoenix.arize.com

# OTLP HTTP collector endpoint for trace export.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces

# Project name traces are written to. Agent SRE reads from this project.
PHOENIX_PROJECT_NAME=match2026-travel

# =============================================================================
# Phoenix MCP server
# =============================================================================
# We use the HTTP transport (not stdio) so we don't need Node.js in the
# Cloud Run container.
PHOENIX_MCP_URL=https://app.phoenix.arize.com/mcp

# =============================================================================
# Cloud Run / persistent sessions (optional for local dev)
# =============================================================================
# Cloud SQL Postgres URL for ADK DatabaseSessionService. Leave blank for local
# in-memory sessions.
SESSION_DB_URL=
